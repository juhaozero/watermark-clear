---
import Layout from '../layouts/Layout.astro';
import ParseForm from '../components/ParseForm';
import ThemeToggle from '../components/ThemeToggle';
---

<Layout>
  <div class="relative flex min-h-screen flex-col">
    <header class="flex items-center justify-end px-6 py-5 sm:px-8">
      <ThemeToggle client:load />
    </header>

    <main class="flex flex-1 flex-col items-center px-6 pb-16 pt-4 sm:px-8">
      <div class="mb-12 text-center">
        <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
          去水印
        </h1>
        <p class="mt-3 max-w-md text-base leading-relaxed text-slate-600 dark:text-slate-400">
          粘贴分享链接，一键解析无水印视频与图集
        </p>
      </div>

      <ParseForm client:load />

      <section class="mt-20 w-full max-w-2xl">
        <h2 class="mb-6 text-center text-xs font-medium uppercase tracking-widest text-slate-400 dark:text-slate-500">
          支持平台
        </h2>
        <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm text-slate-500 dark:text-slate-400">
          <span>抖音</span>
          <span>快手</span>
          <span>小红书</span>
          <span>哔哩哔哩</span>
          <span>微博</span>
          <span>豆包</span>
        </div>
      </section>
    </main>

    <footer class="px-6 py-6 text-center text-xs text-slate-400 dark:text-slate-500">
      <p>仅供学习交流，请尊重原创作者版权</p>
    </footer>
  </div>
</Layout>
